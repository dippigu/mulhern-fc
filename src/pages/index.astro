---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
---

<Layout
  title="Home"
  description="International football assessment and development consultancy. UEFA A Licence coach with 20+ years across elite women's international football, the WSL and the professional men's game."
>
  <!-- Hero -->
  <section class="hero" style={`--hero-image: url('${site.heroImage}')`}>
    <div class="hero__inner container">
      <span class="badge">UEFA A Licence Coach</span>
      <h1>International football assessment<br />and development consultancy</h1>
      <p>
        Independent, honest and development-focused football assessments for
        players, families, clubs, academies and universities across the globe.
      </p>
      <div class="hero__actions">
        <a href="/contact/" class="btn btn--primary">Get in Touch</a>
        <a href="/about/" class="btn btn--outline">About Michael</a>
      </div>
    </div>
  </section>

  <!-- Credentials bar -->
  <section class="credentials section--dark">
    <div class="container">
      <ul class="credentials__list">
        <li>England Women's U-23s</li>
        <li>Women's Super League</li>
        <li>Newcastle United</li>
        <li>The English FA</li>
        <li>International Consultancy</li>
      </ul>
    </div>
  </section>

  <!-- Who I Work With -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Who I Work With</h2>
        <p>
          Players, families, clubs and universities worldwide who want honest,
          objective and development-focused insight. Every assessment is
          delivered remotely with professional standards shaped by elite
          environments, wherever you are based.
        </p>
      </div>

      <div class="audience-grid">
        <div class="audience-card">
          <h3>Younger Players (7-13)</h3>
          <p>For families seeking early, honest clarity on whether a child is showing signs of academy-level potential. Feedback is supportive, realistic and designed to give parents clear next steps.</p>
        </div>
        <div class="audience-card">
          <h3>Players aged 14-18</h3>
          <p>Independent, development-focused assessments for teenage players preparing for academy environments, trials, transitions or university applications.</p>
        </div>
        <div class="audience-card">
          <h3>Players aged 18+</h3>
          <p>Objective support for older youth players progressing towards senior football, university recruitment or structured development planning.</p>
        </div>
        <div class="audience-card">
          <h3>Parents & Families</h3>
          <p>Clear, unbiased insight to help parents make informed decisions about their child's football journey, development needs and realistic pathway options.</p>
        </div>
        <div class="audience-card">
          <h3>Clubs & Academies</h3>
          <p>Independent evaluation, written reports, recruitment support, long-list and short-list creation to strengthen talent identification and internal pathways.</p>
        </div>
        <div class="audience-card">
          <h3>Universities & Agencies</h3>
          <p>Applicant evaluation, suitability checks, recruitment support and performance insight for university football programmes and agency-represented players.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>How It Works</h2>
        <p>A clear and simple process designed to provide honest, development-focused football assessment.</p>
      </div>

      <div class="steps">
        <div class="step">
          <span class="step__number">1</span>
          <h3>Send Your Footage</h3>
          <p>You send your match video link (Veo, YouTube, Hudl etc). I review the footage to ensure it is clear enough for assessment.</p>
        </div>
        <div class="step">
          <span class="step__number">2</span>
          <h3>Assessment Begins</h3>
          <p>I complete a full analysis of the match, assessing technical, tactical, physical and behavioural elements before producing a detailed written report.</p>
        </div>
        <div class="step">
          <span class="step__number">3</span>
          <h3>Receive Your Report</h3>
          <p>Your report is delivered digitally. Depending on the service chosen, you may also receive a Zoom consultation and a full development plan.</p>
        </div>
      </div>

      <div class="steps__addons">
        <h3>Optional add-ons</h3>
        <div class="addons-list">
          <span class="addon">Zoom consultation</span>
          <span class="addon">Development plan</span>
          <span class="addon">Two-match packages</span>
          <span class="addon">In-person assessment (UK only)</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Services</h2>
        <p>
          Every assessment is grounded in elite standards, shaped by
          international football, the WSL and the professional game.
        </p>
      </div>

      <div class="services-split">
        <div class="service-block">
          <div class="service-block__accent"></div>
          <h3>Player Analysis</h3>
          <ul>
            <li>Video match analysis (single &amp; multi-match)</li>
            <li>Three-section assessment report</li>
            <li>Zoom consultation add-ons</li>
            <li>In-person observation (UK only)</li>
            <li>Applicant evaluation for institutions</li>
          </ul>
          <a href="/services/player-analysis/" class="btn btn--primary">View Services</a>
        </div>

        <div class="service-block">
          <div class="service-block__accent service-block__accent--green"></div>
          <h3>Player Pathways</h3>
          <ul>
            <li>Targeted introductions to clubs, academies and universities</li>
            <li>International placement support (UK, USA and beyond)</li>
            <li>Trials, transitions and scholarship pathways</li>
            <li>Long-list and short-list creation for institutions</li>
            <li>Recruitment cycle support</li>
          </ul>
          <a href="/services/player-pathways/" class="btn btn--primary">View Services</a>
        </div>

        <div class="service-block">
          <div class="service-block__accent service-block__accent--navy"></div>
          <h3>Workshops &amp; Presentations</h3>
          <ul>
            <li>Workshops for staff and players</li>
            <li>Coach mentorship</li>
            <li>Tailored topics &amp; programmes</li>
            <li>Online via Zoom or in-person</li>
            <li>Single sessions or multi-week series</li>
          </ul>
          <a href="/services/workshops-and-presentations/" class="btn btn--primary">View Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- International Coverage -->
  <section class="section section--dark">
    <div class="container">
      <div class="global">
        <h2>Working Internationally</h2>
        <p>
          Supporting players, families and institutions across the globe.
          All video assessments, reports and consultations are delivered
          remotely, with the same professional care and attention, wherever
          you are based.
        </p>
        <div class="global__regions">
          <span class="region-pill">United Kingdom</span>
          <span class="region-pill">USA</span>
          <span class="region-pill">China</span>
          <span class="region-pill">Australia</span>
          <span class="region-pill">Middle East</span>
          <span class="region-pill">& Beyond</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container">
      <div class="section__header">
        <h2>Ready to get started?</h2>
        <p>Request more information or discuss your needs today.</p>
      </div>
      <div class="cta__action">
        <a href="/contact/" class="btn btn--primary">Get in Touch</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 7rem 1.5rem 6rem;
    background:
      linear-gradient(135deg, rgba(26, 35, 50, 0.88) 0%, rgba(26, 35, 50, 0.72) 100%),
      var(--hero-image) center / cover no-repeat;
    color: var(--color-white);
  }

  .hero__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero .badge {
    margin-bottom: 1.75rem;
    background-color: rgba(196, 162, 101, 0.15);
  }

  .hero h1 {
    margin-bottom: 1.5rem;
    color: var(--color-white);
  }

  .hero p {
    font-size: 1.125rem;
    color: var(--color-grey-200);
    margin-bottom: 2.5rem;
    max-width: 50ch;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero .btn--outline {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .hero .btn--outline:hover {
    background-color: var(--color-white);
    color: var(--color-navy);
    border-color: var(--color-white);
  }

  /* Credentials */
  .credentials {
    padding: 1.25rem 1.5rem;
  }

  .credentials__list {
    display: flex;
    justify-content: center;
    gap: 2rem;
    list-style: none;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
  }

  .credentials__list li {
    white-space: nowrap;
  }

  /* Audience Grid */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .audience-card {
    padding: 2rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .audience-card:hover {
    border-color: var(--color-gold);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  .audience-card h3 {
    margin-bottom: 0.625rem;
    font-size: 1.0625rem;
  }

  .audience-card p {
    font-size: 0.9375rem;
    color: var(--color-grey-600);
    line-height: 1.6;
  }

  /* Steps */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .step {
    text-align: center;
  }

  .step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3.25rem;
    height: 3.25rem;
    border-radius: 50%;
    background-color: var(--color-navy);
    color: var(--color-gold);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    font-family: var(--font-serif);
  }

  .step h3 {
    margin-bottom: 0.5rem;
  }

  .step p {
    font-size: 0.9375rem;
    color: var(--color-grey-600);
    margin: 0 auto;
  }

  .steps__addons {
    text-align: center;
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--color-grey-200);
  }

  .steps__addons h3 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-grey-400);
    margin-bottom: 1rem;
  }

  .addons-list {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .addon {
    padding: 0.375rem 1rem;
    font-size: 0.875rem;
    color: var(--color-navy);
    background-color: var(--color-white);
    border: 1px solid var(--color-grey-200);
    border-radius: 4px;
    font-weight: 500;
  }

  /* Services Split */
  .services-split {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .service-block {
    position: relative;
    padding: 2.5rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    overflow: hidden;
    transition: box-shadow 0.2s ease;
  }

  .service-block:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  .service-block__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background-color: var(--color-gold);
  }

  .service-block__accent--green {
    background-color: var(--color-green);
  }

  .service-block__accent--navy {
    background-color: var(--color-navy);
  }

  .service-block h3 {
    margin-bottom: 1.25rem;
    font-size: 1.25rem;
  }

  .service-block ul {
    list-style: none;
    margin-bottom: 2rem;
  }

  .service-block li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-grey-600);
  }

  .service-block li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  /* Global */
  .global {
    text-align: center;
  }

  .global h2 {
    margin-bottom: 1.25rem;
  }

  .global h2::after {
    content: '';
    display: block;
    width: 3rem;
    height: 2px;
    background-color: var(--color-gold);
    margin: 1rem auto 0;
  }

  .global p {
    margin: 0 auto 2.5rem;
    max-width: 55ch;
    opacity: 0.85;
    font-size: 1.0625rem;
  }

  .global__regions {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .region-pill {
    display: inline-block;
    padding: 0.625rem 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    transition: border-color 0.2s ease, background-color 0.2s ease;
  }

  .region-pill:hover {
    border-color: var(--color-gold);
    background-color: rgba(196, 162, 101, 0.1);
  }

  /* CTA */
  .cta__action {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 4rem 1.5rem 3.5rem;
    }

    .audience-grid {
      grid-template-columns: 1fr;
    }

    .steps {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .services-split {
      grid-template-columns: 1fr;
    }

    .credentials__list {
      gap: 1rem;
      font-size: 0.75rem;
    }
  }
</style>
