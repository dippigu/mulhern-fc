---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Home"
  description="Elite football assessment and development consultancy. UEFA A Licence coach with 20+ years across international women's football, the WSL and the professional men's game."
>
  <!-- Hero -->
  <section class="hero">
    <div class="hero__inner container">
      <span class="badge">UEFA A Licence Coach</span>
      <h1>Elite football assessment<br />and development consultancy</h1>
      <p>
        Independent, honest and development-focused football assessments for
        players, families, clubs, academies and universities worldwide.
      </p>
      <div class="hero__actions">
        <a href="/contact/" class="btn btn--primary">Get in Touch</a>
        <a href="/about/" class="btn btn--outline">About Michael</a>
      </div>
    </div>
  </section>

  <!-- Credentials bar -->
  <section class="credentials section--dark">
    <div class="container">
      <ul class="credentials__list">
        <li>England Women's U-23s</li>
        <li>Women's Super League</li>
        <li>Newcastle United</li>
        <li>The English FA</li>
        <li>Global Consultancy</li>
      </ul>
    </div>
  </section>

  <!-- Who I Work With -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Who I Work With</h2>
        <p>
          Supporting players and institutions at every level, from early
          development through to elite pathways.
        </p>
      </div>

      <div class="audience-grid">
        <div class="audience-card">
          <h3>Players aged 7-13</h3>
          <p>Early development assessment and academy readiness guidance for younger players and their families.</p>
        </div>
        <div class="audience-card">
          <h3>Players aged 14-18</h3>
          <p>Honest, development-focused assessment with pathway guidance for youth players.</p>
        </div>
        <div class="audience-card">
          <h3>Players aged 18+</h3>
          <p>Support for trials, transitions, university applications and international pathway decisions.</p>
        </div>
        <div class="audience-card">
          <h3>Clubs & Academies</h3>
          <p>Independent evaluation, recruitment support and long-term development consultancy.</p>
        </div>
        <div class="audience-card">
          <h3>Universities</h3>
          <p>Applicant evaluation, recruitment cycle support and programme development.</p>
        </div>
        <div class="audience-card">
          <h3>Agencies</h3>
          <p>Independent assessments and development reviews for represented players.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>How It Works</h2>
      </div>

      <div class="steps">
        <div class="step">
          <span class="step__number">1</span>
          <h3>Get in Touch</h3>
          <p>Tell us about the player or your programme's needs. We'll recommend the right service.</p>
        </div>
        <div class="step">
          <span class="step__number">2</span>
          <h3>Assessment</h3>
          <p>Submit match footage for video analysis, or arrange an in-person observation (UK only).</p>
        </div>
        <div class="step">
          <span class="step__number">3</span>
          <h3>Report & Guidance</h3>
          <p>Receive a clear, structured report with development priorities, pathway guidance and next steps.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Services</h2>
        <p>
          Every assessment is grounded in elite standards, shaped by
          international football, the WSL and the UK's professional game.
        </p>
      </div>

      <div class="services-split">
        <div class="service-block">
          <div class="service-block__accent"></div>
          <h3>Players & Families</h3>
          <ul>
            <li>Development Readiness Assessment (ages 7-13)</li>
            <li>Single & multi-match video analysis</li>
            <li>Enhanced assessments with Zoom consultation</li>
            <li>Full development plans with elite benchmarks</li>
            <li>In-person observation (UK)</li>
          </ul>
          <a href="/services/players/" class="btn btn--primary">View Services</a>
        </div>

        <div class="service-block">
          <div class="service-block__accent service-block__accent--green"></div>
          <h3>Clubs & Institutions</h3>
          <ul>
            <li>Applicant evaluation and reporting</li>
            <li>Long-list and short-list creation</li>
            <li>Recruitment cycle support</li>
            <li>Workshops and coach mentorship</li>
            <li>Institutional retainers</li>
          </ul>
          <a href="/services/institutions/" class="btn btn--primary">View Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Global Coverage -->
  <section class="section section--dark">
    <div class="container">
      <div class="global">
        <h2>Global Coverage</h2>
        <p>
          Supporting players, families and institutions across the United
          Kingdom, USA, China, Australia and the Middle East. All assessments
          are delivered with the same professional care and attention, wherever
          a player is based.
        </p>
        <div class="global__regions">
          <span>United Kingdom</span>
          <span>USA</span>
          <span>China</span>
          <span>Australia</span>
          <span>Middle East</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section cta">
    <div class="container">
      <div class="section__header">
        <h2>Ready to get started?</h2>
        <p>Book your assessment or request more information today.</p>
      </div>
      <div class="cta__action">
        <a href="/contact/" class="btn btn--primary">Contact Michael</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    padding: 6rem 1.5rem 5rem;
    background: linear-gradient(135deg, var(--color-off-white) 0%, var(--color-white) 100%);
  }

  .hero__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero .badge {
    margin-bottom: 1.5rem;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
  }

  .hero p {
    font-size: 1.125rem;
    color: var(--color-grey-600);
    margin-bottom: 2.5rem;
    max-width: 50ch;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Credentials */
  .credentials {
    padding: 1.25rem 1.5rem;
  }

  .credentials__list {
    display: flex;
    justify-content: center;
    gap: 2rem;
    list-style: none;
    flex-wrap: wrap;
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.85;
  }

  .credentials__list li {
    white-space: nowrap;
  }

  /* Audience Grid */
  .audience-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .audience-card {
    padding: 1.75rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .audience-card:hover {
    border-color: var(--color-gold);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  }

  .audience-card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.0625rem;
  }

  .audience-card p {
    font-size: 0.9375rem;
    color: var(--color-grey-600);
    line-height: 1.6;
  }

  /* Steps */
  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.5rem;
  }

  .step {
    text-align: center;
  }

  .step__number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background-color: var(--color-green);
    color: var(--color-white);
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .step h3 {
    margin-bottom: 0.5rem;
  }

  .step p {
    font-size: 0.9375rem;
    color: var(--color-grey-600);
    margin: 0 auto;
  }

  /* Services Split */
  .services-split {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .service-block {
    position: relative;
    padding: 2.5rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    overflow: hidden;
  }

  .service-block__accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background-color: var(--color-gold);
  }

  .service-block__accent--green {
    background-color: var(--color-green);
  }

  .service-block h3 {
    margin-bottom: 1.25rem;
    font-size: 1.25rem;
  }

  .service-block ul {
    list-style: none;
    margin-bottom: 2rem;
  }

  .service-block li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.625rem;
    font-size: 0.9375rem;
    color: var(--color-grey-600);
  }

  .service-block li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  /* Global */
  .global {
    text-align: center;
  }

  .global h2 {
    margin-bottom: 1.25rem;
  }

  .global p {
    margin: 0 auto 2rem;
    max-width: 55ch;
    opacity: 0.85;
    font-size: 1.0625rem;
  }

  .global__regions {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .global__regions span {
    padding: 0.5rem 1.25rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }

  /* CTA */
  .cta__action {
    text-align: center;
  }

  @media (max-width: 768px) {
    .hero {
      padding: 3.5rem 1.5rem 3rem;
    }

    .audience-grid {
      grid-template-columns: 1fr;
    }

    .steps {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .services-split {
      grid-template-columns: 1fr;
    }

    .credentials__list {
      gap: 1rem;
      font-size: 0.75rem;
    }
  }
</style>
