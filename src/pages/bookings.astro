---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Book a Call"
  description="Book an online football consultation call. One-to-one support for players, parents, coaches — covering development, analysis, guidance and pathway planning."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="badge">Online Consultations</span>
      <h1>Book an online football call</h1>
      <p class="page-header__subtitle">
        This is your space to talk football in detail — whether you're a player,
        parent, or coach, wherever you are in the world. Each call is tailored
        to your needs.
      </p>
    </div>
  </section>

  <!-- What's Included -->
  <section class="section">
    <div class="container">
      <div class="booking-layout">
        <div class="booking-main">
          <h2>What we can cover</h2>
          <ul class="feature-list">
            <li>Reviewing your match or training footage</li>
            <li>Technical, tactical, or positional guidance</li>
            <li>Development planning and next-step advice</li>
            <li>Strengths and improvements</li>
            <li>Support for parents navigating the football pathway</li>
            <li>Session ideas, coaching guidance, or age-group development</li>
            <li>Talking through football issues, challenges, or decisions</li>
            <li>General football conversation and support</li>
          </ul>
          <p class="booking-note">If it's football-related, we can talk about it.</p>
        </div>

        <aside class="booking-sidebar">
          <div class="price-card">
            <h3>Online Football Call</h3>
            <div class="price-card__price">
              <span class="price-card__amount">£49.99</span>
              <span class="price-card__unit">per hour</span>
            </div>
            <a href="#" class="btn btn--primary btn--full">Book Now</a>
          </div>

          <div class="info-card">
            <h3>Call Duration</h3>
            <p>Online calls typically last 60 minutes. I can be flexible depending on your availability and needs.</p>
          </div>

          <div class="info-card">
            <h3>What You Need</h3>
            <ul>
              <li>A phone, tablet, or laptop</li>
              <li>A stable internet connection (unless choosing mobile call)</li>
              <li>Any video clips you'd like to discuss (optional)</li>
            </ul>
            <p class="info-card__note">You'll receive call details immediately after booking.</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Preferred call method</h2>
        <p>You can pick the platform that works best for your location.</p>
      </div>

      <div class="platforms-grid">
        <div class="platform-card">
          <h3>Zoom</h3>
          <p>Standard option for most countries.</p>
        </div>
        <div class="platform-card">
          <h3>VooV Meeting</h3>
          <p>Highly reliable for mainland China (Tencent Meeting).</p>
        </div>
        <div class="platform-card">
          <h3>Microsoft Teams</h3>
          <p>Strong alternative for all regions.</p>
        </div>
        <div class="platform-card">
          <h3>Mobile Call</h3>
          <p>Ideal for low-internet access or audio-only preferences.</p>
        </div>
      </div>

      <p class="platforms-note">You'll select your preferred method during booking.</p>
    </div>
  </section>

  <!-- China Notice -->
  <section class="section">
    <div class="container">
      <div class="china-notice">
        <h2>Joining from China</h2>
        <p>
          Internet restrictions can affect some platforms.
          <strong>VooV Meeting</strong> or <strong>Microsoft Teams</strong> will
          provide the most reliable connection.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Not sure what you need?</h2>
        <p>Feel free to ask before booking — I'm happy to help and always available.</p>
      </div>
      <div class="cta__action">
        <a href="mailto:michael@mulhernfc.com" class="btn btn--primary">Email Michael</a>
        <a href="/contact/" class="btn btn--outline">Contact Form</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    background-color: var(--color-off-white);
  }

  .page-header .badge {
    margin-bottom: 1rem;
  }

  .page-header__subtitle {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--color-grey-600);
    max-width: 50ch;
  }

  /* Booking Layout */
  .booking-layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
    align-items: start;
  }

  .booking-main h2 {
    margin-bottom: 1.5rem;
  }

  .booking-main h2::after {
    content: '';
    display: block;
    width: 3rem;
    height: 2px;
    background-color: var(--color-gold);
    margin: 1rem 0 0;
  }

  .feature-list {
    list-style: none;
    margin-bottom: 1.5rem;
  }

  .feature-list li {
    position: relative;
    padding: 0.625rem 0 0.625rem 1.5rem;
    font-size: 0.9375rem;
    color: var(--color-grey-600);
    border-bottom: 1px solid var(--color-grey-100);
  }

  .feature-list li:last-child {
    border-bottom: none;
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  .booking-note {
    font-style: italic;
    color: var(--color-grey-600);
    font-size: 0.9375rem;
  }

  /* Sidebar */
  .booking-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .price-card {
    padding: 2rem;
    background-color: var(--color-navy);
    border-radius: 6px;
    color: var(--color-white);
    text-align: center;
  }

  .price-card h3 {
    color: var(--color-white);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .price-card__price {
    margin-bottom: 1.5rem;
  }

  .price-card__amount {
    display: block;
    font-family: var(--font-serif);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
  }

  .price-card__unit {
    font-size: 0.875rem;
    color: var(--color-grey-400);
    margin-top: 0.25rem;
    display: block;
  }

  .btn--full {
    display: block;
    width: 100%;
  }

  .info-card {
    padding: 1.5rem;
    background-color: var(--color-off-white);
    border-radius: 6px;
  }

  .info-card h3 {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-grey-400);
    margin-bottom: 0.625rem;
  }

  .info-card p {
    font-size: 0.9375rem;
    color: var(--color-navy);
  }

  .info-card ul {
    list-style: none;
    margin-bottom: 0.75rem;
  }

  .info-card li {
    position: relative;
    padding-left: 1rem;
    font-size: 0.875rem;
    color: var(--color-navy);
    margin-bottom: 0.375rem;
  }

  .info-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  .info-card__note {
    font-size: 0.8125rem;
    color: var(--color-grey-400);
    font-style: italic;
  }

  /* Platforms */
  .platforms-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .platform-card {
    padding: 1.75rem;
    background-color: var(--color-white);
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    text-align: center;
    transition: border-color 0.2s ease;
  }

  .platform-card:hover {
    border-color: var(--color-gold);
  }

  .platform-card h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .platform-card p {
    font-size: 0.8125rem;
    color: var(--color-grey-600);
  }

  .platforms-note {
    text-align: center;
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-grey-400);
  }

  /* China Notice */
  .china-notice {
    max-width: 640px;
    margin: 0 auto;
    padding: 2.5rem;
    background-color: var(--color-off-white);
    border-radius: 6px;
    border-left: 3px solid var(--color-gold);
  }

  .china-notice h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .china-notice p {
    color: var(--color-grey-600);
    font-size: 0.9375rem;
  }

  .cta__action {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .booking-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .platforms-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
