---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Agency Partnerships"
  description="Independent football assessments and objective insight for agencies supporting represented players."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="badge">Partnerships</span>
      <h1>Agency Partnerships</h1>
      <p class="page-header__subtitle">
        I support agencies by providing independent football assessments and
        clear, objective insight for represented players. My evaluations are
        shaped by more than two decades of experience across international
        women's football, the WSL and the UK's professional men's game.
      </p>
    </div>
  </section>

  <!-- What Your Agency Receives -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>What Your Agency Receives</h2>
      </div>

      <ul class="feature-list">
        <li>Independent evaluation of represented players</li>
        <li>Detailed written reports</li>
        <li>Strengths and development priorities</li>
        <li>Position-specific insights</li>
        <li>Suitability analysis for trials, universities or pathways</li>
        <li>Support for agency-led recruitment decisions</li>
        <li>Zoom consultations with players or families</li>
        <li>Fast turnaround and priority access</li>
      </ul>
    </div>
  </section>

  <!-- Packages -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Agency Partnership Packages</h2>
      </div>

      <div class="packages-grid">
        <div class="package-card">
          <h3>Assessment Package</h3>
          <p>A set number of player reports per cycle.</p>
        </div>

        <div class="package-card">
          <h3>Recruitment Support Package</h3>
          <p>Suitability analysis and pathway guidance.</p>
        </div>

        <div class="package-card">
          <h3>Full Agency Partnership</h3>
          <p>Year-round support, consultations and priority access.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Ready to explore a partnership?</h2>
        <p>Get in touch to discuss the right package for your agency.</p>
      </div>
      <div class="cta__action">
        <a href="/contact/" class="btn btn--primary">Contact Michael</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    background-color: var(--color-off-white);
  }

  .page-header .badge {
    margin-bottom: 1rem;
  }

  .page-header__subtitle {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--color-grey-600);
    max-width: 55ch;
  }

  .feature-list {
    list-style: none;
    max-width: 640px;
    margin: 0 auto;
  }

  .feature-list li {
    position: relative;
    padding: 0.75rem 0 0.75rem 1.5rem;
    font-size: 1.0625rem;
    color: var(--color-grey-600);
    border-bottom: 1px solid var(--color-grey-100);
  }

  .feature-list li:last-child {
    border-bottom: none;
  }

  .feature-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.1em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  .packages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .package-card {
    padding: 2.25rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    background-color: var(--color-white);
    transition: border-color 0.2s ease;
  }

  .package-card:hover {
    border-color: var(--color-green);
  }

  .package-card h3 {
    margin-bottom: 0.75rem;
  }

  .package-card p {
    color: var(--color-grey-600);
    font-size: 0.9375rem;
  }

  .cta__action {
    text-align: center;
  }

  @media (max-width: 768px) {
    .packages-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
