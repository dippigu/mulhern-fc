---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Middle East Football Assessment Services"
  description="Honest, development-focused football assessments for players and families in the Middle East. Video analysis, written reports and Zoom consultations."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="badge">Middle East</span>
      <h1>Football assessment services for players & families in the Middle East</h1>
      <p class="page-header__subtitle">
        I provide honest, development-focused football assessments for players
        and families in the Middle East. With more than two decades of experience
        across elite women's football, the WSL and the men's professional
        environment, I offer clear, objective insight into a player's level and
        pathway potential.
      </p>
    </div>
  </section>

  <!-- What I Offer -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>What I offer in the Middle East</h2>
      </div>
      <div class="offerings-grid">
        <div class="offering">Full match video analysis</div>
        <div class="offering">Written reports</div>
        <div class="offering">Strengths and development priorities</div>
        <div class="offering">Development plans</div>
        <div class="offering">Zoom consultations</div>
        <div class="offering">Pathway guidance</div>
      </div>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Who this is for</h2>
      </div>
      <div class="for-grid">
        <div class="for-item">Players aged 14-18</div>
        <div class="for-item">Players aged 18+</div>
        <div class="for-item">Families seeking clear insight</div>
        <div class="for-item">Academy and grassroots players</div>
        <div class="for-item">Players preparing for trials</div>
        <div class="for-item">Players applying to colleges or universities</div>
        <div class="for-item">Players who want to play overseas</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Ready to get started?</h2>
        <p>Book an assessment or get in touch to discuss your needs.</p>
      </div>
      <div class="cta__action">
        <a href="/bookings/" class="btn btn--primary">Book a Call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    background-color: var(--color-off-white);
  }

  .page-header .badge {
    margin-bottom: 1rem;
  }

  .page-header__subtitle {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--color-grey-600);
    max-width: 55ch;
  }

  .offerings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .offering {
    padding: 1.25rem 1.5rem;
    background-color: var(--color-off-white);
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-navy);
    text-align: center;
    border: 1px solid var(--color-grey-200);
  }

  .for-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .for-item {
    display: flex;
    align-items: start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background-color: var(--color-white);
    border-radius: 6px;
    font-size: 0.9375rem;
    color: var(--color-navy);
    font-weight: 500;
  }

  .for-item::before {
    content: '';
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-green);
    margin-top: 0.45rem;
  }

  .cta__action {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .offerings-grid {
      grid-template-columns: 1fr;
    }

    .for-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
