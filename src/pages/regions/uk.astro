---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="UK Football Assessment Services"
  description="Honest, development-focused football assessments for players and families in the United Kingdom. Video analysis, written reports, Zoom consultations and in-person assessments."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="badge">United Kingdom</span>
      <h1>Football assessment services for UK players & families</h1>
      <p class="page-header__subtitle">
        I provide honest, development-focused football assessments for players
        and families in the UK. With more than two decades of experience across
        elite women's football, the WSL and the men's professional environment,
        I offer clear, objective insight into a player's level and pathway potential.
      </p>
    </div>
  </section>

  <!-- Younger Players -->
  <section class="section">
    <div class="container">
      <div class="highlight-block">
        <h2>For parents of younger players</h2>
        <p>
          Parents of younger players often want clarity on whether their child is
          showing early signs of academy-level potential or progressing at the right
          pace. I provide independent, age-appropriate assessment to help families
          understand where their child currently stands and what they may need next.
        </p>
        <ul class="feature-list feature-list--compact">
          <li>Early technical, tactical and behavioural insight</li>
          <li>Age-appropriate development priorities</li>
          <li>Honest guidance on academy readiness</li>
          <li>Advice on whether a player may be ready now, later, or not yet</li>
          <li>Recommendations on training, positioning and next steps</li>
          <li>Clear, supportive feedback for parents</li>
        </ul>
        <p class="highlight-block__note">
          This is ideal for families looking for professional clarity without
          pressure, agendas or unrealistic expectations.
        </p>
      </div>
    </div>
  </section>

  <!-- What I Offer -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>What I offer in the UK</h2>
      </div>
      <div class="offerings-grid">
        <div class="offering">Full match video analysis</div>
        <div class="offering">Written reports</div>
        <div class="offering">Strengths and development priorities</div>
        <div class="offering">Development plans</div>
        <div class="offering">Zoom consultations</div>
        <div class="offering">Pathway guidance</div>
      </div>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Who this is for</h2>
      </div>
      <div class="for-grid">
        <div class="for-item">Younger players (7-13) whose parents want clarity on early development and academy readiness</div>
        <div class="for-item">Players aged 14-18</div>
        <div class="for-item">Players aged 18+</div>
        <div class="for-item">Families seeking clear insight</div>
        <div class="for-item">Academy and grassroots players</div>
        <div class="for-item">Players preparing for trials</div>
        <div class="for-item">Players applying to universities or colleges</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Ready to get started?</h2>
        <p>Book an assessment or get in touch to discuss your needs.</p>
      </div>
      <div class="cta__action">
        <a href="/bookings/" class="btn btn--primary">Book a Call</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    background-color: var(--color-off-white);
  }

  .page-header .badge {
    margin-bottom: 1rem;
  }

  .page-header__subtitle {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--color-grey-600);
    max-width: 55ch;
  }

  .highlight-block {
    max-width: 720px;
    margin: 0 auto;
  }

  .highlight-block h2 {
    margin-bottom: 1.25rem;
  }

  .highlight-block h2::after {
    content: '';
    display: block;
    width: 3rem;
    height: 2px;
    background-color: var(--color-gold);
    margin: 1rem 0 0;
  }

  .highlight-block > p {
    color: var(--color-grey-600);
    margin-bottom: 1.5rem;
  }

  .highlight-block__note {
    font-style: italic;
    color: var(--color-grey-600);
    margin-top: 1.5rem;
  }

  .feature-list--compact {
    list-style: none;
  }

  .feature-list--compact li {
    position: relative;
    padding: 0.5rem 0 0.5rem 1.5rem;
    font-size: 0.9375rem;
    color: var(--color-grey-600);
  }

  .feature-list--compact li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.95em;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  .offerings-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .offering {
    padding: 1.25rem 1.5rem;
    background-color: var(--color-white);
    border-radius: 6px;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-navy);
    text-align: center;
    border: 1px solid var(--color-grey-200);
  }

  .for-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 720px;
    margin: 0 auto;
  }

  .for-item {
    display: flex;
    align-items: start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background-color: var(--color-off-white);
    border-radius: 6px;
    font-size: 0.9375rem;
    color: var(--color-navy);
    font-weight: 500;
  }

  .for-item::before {
    content: '';
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-green);
    margin-top: 0.45rem;
  }

  .cta__action {
    display: flex;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .offerings-grid {
      grid-template-columns: 1fr;
    }

    .for-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
