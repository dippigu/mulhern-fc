---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Services for Players & Families"
  description="Honest, development-focused football assessments for players aged 7-18+. Grounded in elite standards shaped by international football, the WSL and the UK's professional game."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="badge">Individual Services</span>
      <h1>Players & Families</h1>
      <p class="page-header__subtitle">
        Honest, development-focused football assessments for players aged 7-18+.
        Every assessment is grounded in elite standards shaped by international
        football, the WSL and the UK's professional game.
      </p>
    </div>
  </section>

  <!-- Services -->
  <section class="section">
    <div class="container">
      <div class="services-list">
        <!-- Development Readiness -->
        <div class="service-card service-card--featured">
          <div class="service-card__top">
            <span class="service-card__label">Ages 7-13</span>
            <h2>Development Readiness Assessment</h2>
            <div class="service-card__price">
              <span class="service-card__amount">£59.99</span>
              <span class="service-card__unit">per assessment</span>
            </div>
            <p>
              A clear, age-appropriate assessment designed to help parents
              understand whether a younger player is showing early signs of
              academy-level potential. The assessment focuses on foundational
              technical ability, early tactical awareness, physical readiness,
              and behaviours appropriate to the player's age.
            </p>
          </div>
          <div class="service-card__details">
            <h3>What's included</h3>
            <ul>
              <li>Review of one recent match or training video</li>
              <li>Early technical and game-understanding indicators</li>
              <li>Development priorities tailored to age and stage</li>
              <li>Clear guidance on academy readiness (ready now / ready later / still developing)</li>
              <li>Supportive next-step recommendations for parents</li>
              <li>Optional Zoom call for further explanation</li>
            </ul>
            <p class="service-card__note">
              This service gives families reassurance, clarity and direction at
              an important early stage of development.
            </p>
          </div>
        </div>

        <!-- Single Match -->
        <div class="service-card">
          <h2>Single Match Video Assessment</h2>
          <div class="service-card__price">
            <span class="service-card__amount">£79.99</span>
            <span class="service-card__unit">per assessment</span>
          </div>
          <p>
            A full analysis of one complete match covering technical, tactical,
            physical and psychological factors. You receive a clear, structured
            report outlining strengths, development priorities and pathway
            guidance.
          </p>
        </div>

        <!-- Enhanced -->
        <div class="service-card">
          <span class="service-card__label">Most Popular</span>
          <h2>Enhanced Assessment + Zoom Call</h2>
          <div class="service-card__price">
            <span class="service-card__amount">£129.99</span>
            <span class="service-card__unit">per assessment</span>
          </div>
          <p>
            Includes everything in the Single Match Assessment plus a one-to-one
            Zoom consultation to review your report, discuss goals and plan next
            steps. Parents may join the call.
          </p>
        </div>

        <!-- Premium -->
        <div class="service-card">
          <h2>Premium Assessment + Development Plan</h2>
          <div class="service-card__price">
            <span class="service-card__amount">£179.99</span>
            <span class="service-card__unit">per assessment</span>
          </div>
          <p>
            A deeper, more comprehensive service including a full written
            development plan with position-specific priorities, short-term and
            long-term recommendations and elite-standard benchmarks.
          </p>
        </div>

        <!-- Two-Match -->
        <div class="service-card">
          <h2>Two-Match Assessment Package</h2>
          <div class="service-card__price">
            <span class="service-card__amount">£149.99</span>
            <span class="service-card__unit">for two matches</span>
          </div>
          <p>
            Two full match analyses providing clarity on performance consistency,
            behavioural patterns and decision-making trends. Offers a more
            complete understanding of player development needs.
          </p>
        </div>

        <!-- Two-Match Premium -->
        <div class="service-card">
          <h2>Two-Match Premium Package</h2>
          <div class="service-card__price">
            <span class="service-card__amount">£279.99</span>
            <span class="service-card__unit">for two matches</span>
          </div>
          <p>
            Includes two match assessments, a development plan and a Zoom
            consultation. Designed for players seeking long-term development
            support.
          </p>
        </div>

        <!-- In-Person -->
        <div class="service-card">
          <h2>In-Person UK Assessment</h2>
          <div class="service-card__price">
            <span class="service-card__amount">£299.99</span>
            <span class="service-card__unit">per assessment + travel</span>
          </div>
          <p>
            Live match or training observation (UK only), followed by immediate
            feedback and a detailed written report. Travel costs may apply
            depending on location.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Who This Is For</h2>
      </div>

      <div class="for-grid">
        <div class="for-item">Younger players (aged 7-13) whose parents want clarity on early development and academy readiness</div>
        <div class="for-item">Players aged 14-18 seeking honest assessment and development guidance</div>
        <div class="for-item">Players aged 18+ preparing for trials, applications or pathway progression</div>
        <div class="for-item">Parents and families seeking clarity and unbiased, development-focused feedback</div>
        <div class="for-item">Academy and grassroots players</div>
        <div class="for-item">Players preparing for transitions, trials or university applications</div>
        <div class="for-item">Players considering UK, USA or international pathways</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Get in touch to discuss your needs</h2>
        <p>Every player is different. Contact Michael to find the right assessment for you.</p>
      </div>
      <div class="cta__action">
        <a href="/contact/" class="btn btn--primary">Contact Michael</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    background-color: var(--color-off-white);
  }

  .page-header .badge {
    margin-bottom: 1rem;
  }

  .page-header__subtitle {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--color-grey-600);
    max-width: 55ch;
  }

  /* Services List */
  .services-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .service-card {
    padding: 2.5rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    transition: border-color 0.2s ease;
  }

  .service-card:hover {
    border-color: var(--color-gold);
  }

  .service-card h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .service-card__price {
    margin-bottom: 1rem;
  }

  .service-card__amount {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-gold);
    line-height: 1;
  }

  .service-card__unit {
    font-size: 0.8125rem;
    color: var(--color-grey-400);
    margin-left: 0.375rem;
  }

  .service-card p {
    color: var(--color-grey-600);
    font-size: 0.9375rem;
  }

  /* Featured Card */
  .service-card--featured {
    border: 2px solid var(--color-gold);
    background: linear-gradient(to bottom, rgba(184, 134, 11, 0.03), transparent);
  }

  .service-card__label {
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: var(--color-green);
    color: var(--color-white);
    border-radius: 3px;
    margin-bottom: 1rem;
  }

  .service-card__details {
    margin-top: 1.75rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-grey-200);
  }

  .service-card__details h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .service-card__details ul {
    list-style: none;
    margin-bottom: 1.25rem;
  }

  .service-card__details li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.5rem;
    font-size: 0.9375rem;
    color: var(--color-grey-600);
  }

  .service-card__details li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: var(--color-gold);
  }

  .service-card__note {
    font-style: italic;
    font-size: 0.9375rem;
    color: var(--color-grey-600);
  }

  /* Who This Is For */
  .for-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .for-item {
    display: flex;
    align-items: start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background-color: var(--color-white);
    border-radius: 6px;
    font-size: 0.9375rem;
    color: var(--color-navy);
    font-weight: 500;
  }

  .for-item::before {
    content: '';
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-green);
    margin-top: 0.45rem;
  }

  .cta__action {
    text-align: center;
  }

  @media (max-width: 768px) {
    .for-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      padding: 1.75rem;
    }
  }
</style>
