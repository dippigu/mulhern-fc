---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Services for Players & Families"
  description="Honest, development-focused football assessments for players aged 7-18+. Grounded in elite standards shaped by international football, the WSL and the UK's professional game."
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <span class="badge">Individual Services</span>
      <h1>Players & Families</h1>
      <p class="page-header__subtitle">
        Honest, development-focused football assessments for players aged 7-18+.
        Every assessment is grounded in elite standards shaped by international
        football, the WSL and the UK's professional game.
      </p>
    </div>
  </section>

  <!-- The Report -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>The Assessment Report</h2>
        <p>
          Every assessment produces a comprehensive, approximately 40-page report
          built around three interconnected sections. These sections are designed
          to work together as a complete unit — giving the parent clarity, the
          player direction, and the family a practical framework for development.
        </p>
      </div>

      <div class="report-tiers">
        <div class="report-tier">
          <span class="report-tier__badge">Match Analysis</span>
          <h3>Technical & Tactical Assessment</h3>
          <p class="report-tier__audience">For the parent or guardian</p>
          <p>
            A detailed written assessment of the player's technical ability,
            tactical understanding, physical attributes and behaviours. Written
            for parents, this section gives honest, clear development priorities
            using elite-standard benchmarks. No jargon. No false positivity.
          </p>
        </div>

        <div class="report-tier">
          <span class="report-tier__badge">Player Letter</span>
          <h3>A Personal Message to the Player</h3>
          <p class="report-tier__audience">For the player</p>
          <p>
            A written section addressed personally to the player. This is a
            powerful psychological tool — particularly for younger players — that
            communicates development areas with honesty and encouragement directly
            from a UEFA A Licence coach. Many players have never received feedback
            at this level.
          </p>
        </div>

        <div class="report-tier">
          <span class="report-tier__badge">Development Playbook</span>
          <h3>A Practical Guide for the Family</h3>
          <p class="report-tier__audience">For the family</p>
          <p>
            This section equips families with the knowledge to actively support
            the player's development. It covers the sessions needed, the
            behaviours to encourage, and how to help without hindering. Most
            families want to help but don't know how — this gives them a
            practical framework.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Video Analysis -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Video Analysis</h2>
        <p>
          Submit match footage for a full assessment. Every package includes the
          complete three-section report: Match Analysis, Player Letter and
          Development Playbook.
        </p>
      </div>

      <div class="pricing-tables">
        <div class="pricing-table">
          <h3>Assessment Report</h3>
          <div class="pricing-rows">
            <div class="pricing-row">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Single Match Report</span>
                <span class="pricing-row__detail">1 game</span>
              </div>
              <span class="pricing-row__price">£149</span>
            </div>
            <div class="pricing-row pricing-row--recommended">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Standard Assessment</span>
                <span class="pricing-row__detail">2 games</span>
                <span class="pricing-row__label">Recommended</span>
              </div>
              <span class="pricing-row__price">£249</span>
            </div>
            <div class="pricing-row">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Extended Assessment</span>
                <span class="pricing-row__detail">3 games</span>
              </div>
              <span class="pricing-row__price">£329</span>
            </div>
            <div class="pricing-row">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Full Assessment</span>
                <span class="pricing-row__detail">4 games</span>
              </div>
              <span class="pricing-row__price">£399</span>
            </div>
          </div>
        </div>

        <div class="pricing-table">
          <h3>Assessment Report + Zoom Consultation</h3>
          <p class="pricing-table__desc">
            Everything in the assessment report, plus a one-to-one Zoom call to
            talk through the findings. Parents are welcome to join.
          </p>
          <div class="pricing-rows">
            <div class="pricing-row pricing-row--recommended">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Standard + Zoom</span>
                <span class="pricing-row__detail">2 games</span>
                <span class="pricing-row__label">Recommended</span>
              </div>
              <span class="pricing-row__price">£319</span>
            </div>
            <div class="pricing-row">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Extended + Zoom</span>
                <span class="pricing-row__detail">3 games</span>
              </div>
              <span class="pricing-row__price">£399</span>
            </div>
            <div class="pricing-row">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Full + Zoom</span>
                <span class="pricing-row__detail">4 games</span>
              </div>
              <span class="pricing-row__price">£479</span>
            </div>
          </div>
        </div>
      </div>

      <div class="caveat">
        <p>
          <strong>A note on single-match assessments:</strong> A single game may
          not fully represent a player's habits, consistency or decision-making
          patterns. We recommend a minimum of two matches for the most accurate
          and representative assessment. The single-match option is available for
          those seeking an initial overview, but should not be considered a
          complete picture.
        </p>
      </div>
    </div>
  </section>

  <!-- In-Person -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>In-Person Assessment</h2>
        <p>
          Live observation of a match or training session in the North of England,
          followed by the full three-section assessment report.
        </p>
      </div>

      <div class="pricing-tables pricing-tables--centred">
        <div class="pricing-table">
          <div class="pricing-rows">
            <div class="pricing-row">
              <div class="pricing-row__info">
                <span class="pricing-row__name">In-Person Standard</span>
                <span class="pricing-row__detail">Live observation + full report</span>
              </div>
              <span class="pricing-row__price">£299</span>
            </div>
            <div class="pricing-row pricing-row--recommended">
              <div class="pricing-row__info">
                <span class="pricing-row__name">In-Person Premium</span>
                <span class="pricing-row__detail">Live observation + full report + Zoom follow-up</span>
                <span class="pricing-row__label">Best Value</span>
              </div>
              <span class="pricing-row__price">£369</span>
            </div>
            <div class="pricing-row">
              <div class="pricing-row__info">
                <span class="pricing-row__name">Zoom Follow-Up</span>
                <span class="pricing-row__detail">Add-on for existing in-person clients</span>
              </div>
              <span class="pricing-row__price">£75</span>
            </div>
          </div>
        </div>
      </div>

      <div class="pricing-tables--centred">
        <p class="travel-note">
          Travel costs may apply outside the immediate North East area.
        </p>
      </div>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__header">
        <h2>Who This Is For</h2>
      </div>

      <div class="for-grid">
        <div class="for-item">Younger players (aged 7-13) whose parents want clarity on early development and academy readiness</div>
        <div class="for-item">Players aged 14-18 seeking honest assessment and development guidance</div>
        <div class="for-item">Players aged 18+ preparing for trials, applications or pathway progression</div>
        <div class="for-item">Parents and families seeking clarity and unbiased, development-focused feedback</div>
        <div class="for-item">Academy and grassroots players at any level</div>
        <div class="for-item">Players preparing for transitions, trials or university applications</div>
        <div class="for-item">Players considering UK, USA or international pathways</div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <h2>Get in touch to discuss your needs</h2>
        <p>Every player is different. Contact Michael to find the right assessment for you.</p>
      </div>
      <div class="cta__action">
        <a href="/contact/" class="btn btn--primary">Contact Michael</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding: 4rem 1.5rem 2rem;
    background-color: var(--color-off-white);
  }

  .page-header .badge {
    margin-bottom: 1rem;
  }

  .page-header__subtitle {
    margin-top: 1.25rem;
    font-size: 1.0625rem;
    color: var(--color-grey-600);
    max-width: 55ch;
  }

  /* Report Tiers */
  .report-tiers {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .report-tier {
    padding: 2rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
    transition: border-color 0.2s ease;
  }

  .report-tier:hover {
    border-color: var(--color-gold);
  }

  .report-tier h3 {
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }

  .report-tier__audience {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-gold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }

  .report-tier p:last-child {
    color: var(--color-grey-600);
    font-size: 0.9375rem;
  }

  .report-tier__badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 3px;
    margin-bottom: 1rem;
    color: var(--color-white);
    background-color: var(--color-green);
  }

  /* Pricing Tables */
  .pricing-tables {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 1rem;
  }

  .pricing-table {
    padding: 2rem;
    border: 1px solid var(--color-grey-200);
    border-radius: 6px;
  }

  .pricing-table h3 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
  }

  .pricing-table__desc {
    font-size: 0.875rem;
    color: var(--color-grey-600);
    margin-bottom: 1rem;
  }

  .pricing-rows {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pricing-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid var(--color-grey-200);
  }

  .pricing-row:last-child {
    border-bottom: none;
  }

  .pricing-row--recommended {
    background-color: rgba(184, 134, 11, 0.04);
    margin: 0 -1rem;
    padding: 1rem;
    border-radius: 4px;
    border-bottom: 1px solid var(--color-grey-200);
  }

  .pricing-row__info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .pricing-row__name {
    font-weight: 600;
    font-size: 0.9375rem;
    color: var(--color-navy);
  }

  .pricing-row__detail {
    font-size: 0.8125rem;
    color: var(--color-grey-400);
  }

  .pricing-row__label {
    display: inline-block;
    width: fit-content;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: var(--color-green);
    color: var(--color-white);
    border-radius: 3px;
    margin-top: 0.25rem;
  }

  .pricing-row__price {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-gold);
    white-space: nowrap;
  }

  /* Caveat */
  .caveat {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    background-color: var(--color-off-white);
    border-left: 3px solid var(--color-gold);
    border-radius: 0 4px 4px 0;
  }

  .caveat p {
    font-size: 0.875rem;
    color: var(--color-grey-600);
    line-height: 1.6;
  }

  .pricing-tables--centred {
    grid-template-columns: 1fr;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Travel Note */
  .travel-note {
    margin-top: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-grey-400);
    font-style: italic;
    text-align: center;
  }

  /* Who This Is For */
  .for-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .for-item {
    display: flex;
    align-items: start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background-color: var(--color-white);
    border-radius: 6px;
    font-size: 0.9375rem;
    color: var(--color-navy);
    font-weight: 500;
  }

  .for-item::before {
    content: '';
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: var(--color-green);
    margin-top: 0.45rem;
  }

  .cta__action {
    text-align: center;
  }

  @media (max-width: 768px) {
    .report-tiers {
      grid-template-columns: 1fr;
    }

    .pricing-tables {
      grid-template-columns: 1fr;
    }

    .for-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
