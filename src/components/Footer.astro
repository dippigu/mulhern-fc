---
import site from '../data/site.json';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <img
          src={site.profileImage}
          alt="Michael Mulhern Football Consultancy"
          class="footer__logo-img"
          width="56"
          height="56"
        />
        <p class="footer__tagline">Elite football assessment and development consultancy.</p>
      </div>

      <div class="footer__links">
        <div class="footer__col">
          <h4 class="footer__heading">Services</h4>
          <ul>
            <li><a href="/services/player-analysis/">Player Analysis</a></li>
            <li><a href="/services/player-pathways/">Player Pathways</a></li>
            <li><a href="/services/workshops-and-presentations/">Workshops & Presentations</a></li>
          </ul>
        </div>

        <div class="footer__col">
          <h4 class="footer__heading">Company</h4>
          <ul>
            <li><a href="/about/">About</a></li>
            <li><a href="/testimonials/">Testimonials</a></li>
            <li><a href="/faqs/">FAQs</a></li>
            <li><a href="/contact/">Contact</a></li>
          </ul>
        </div>

        <div class="footer__col">
          <h4 class="footer__heading">Legal</h4>
          <ul>
            <li><a href="/privacy-policy/">Privacy Policy</a></li>
            <li><a href="/terms-of-service/">Terms of Service</a></li>
            <li><a href="/cookie-policy/">Cookie Policy</a></li>
            <li><a href="/copyright/">Copyright</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p>&copy; {currentYear} Michael Mulhern Football Consultancy Ltd. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-navy);
    color: var(--color-grey-400);
    padding: 3.5rem 0 0;
  }

  .footer__top {
    display: flex;
    justify-content: space-between;
    gap: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid var(--color-navy-light);
  }

  .footer__brand {
    max-width: 280px;
  }

  .footer__logo-img {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .footer__tagline {
    margin-top: 1rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .footer__links {
    display: flex;
    gap: 4rem;
  }

  .footer__heading {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-white);
    margin-bottom: 1rem;
  }

  .footer__col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer__col a {
    font-size: 0.875rem;
    transition: color 0.15s ease;
  }

  .footer__col a:hover {
    color: var(--color-gold);
  }

  .footer__bottom {
    padding: 1.5rem 0;
    font-size: 0.8125rem;
  }

  @media (max-width: 768px) {
    .footer__top {
      flex-direction: column;
    }

    .footer__links {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
    }
  }
</style>
