---
const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Players & Families', href: '/services/players/' },
  { label: 'Clubs & Institutions', href: '/services/institutions/' },
  { label: 'Contact', href: '/contact/' },
];
---

<header class="header">
  <div class="header__inner container">
    <a href="/" class="header__brand">
      <span class="header__logo">MMulFC</span>
    </a>

    <button class="header__toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="header__toggle-bar"></span>
      <span class="header__toggle-bar"></span>
      <span class="header__toggle-bar"></span>
    </button>

    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__list">
        {navItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={['header__link', { 'header__link--active': currentPath === href }]}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.header__toggle');
  const nav = document.querySelector('.header__nav');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('header__nav--open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-grey-200);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header__logo {
    font-size: 1.375rem;
    font-weight: 800;
    color: var(--color-navy);
    letter-spacing: -0.02em;
  }

  .header__nav {
    display: flex;
  }

  .header__list {
    display: flex;
    gap: 0.25rem;
    list-style: none;
  }

  .header__link {
    display: block;
    padding: 0.5rem 0.875rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-grey-600);
    border-radius: 4px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .header__link:hover {
    color: var(--color-navy);
    background-color: var(--color-grey-100);
  }

  .header__link--active {
    color: var(--color-navy);
    font-weight: 600;
  }

  .header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .header__toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-navy);
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 768px) {
    .header__toggle {
      display: flex;
    }

    .header__nav {
      display: none;
      position: absolute;
      top: 4rem;
      left: 0;
      right: 0;
      background-color: var(--color-white);
      border-bottom: 1px solid var(--color-grey-200);
      padding: 1rem 1.5rem;
    }

    .header__nav--open {
      display: block;
    }

    .header__list {
      flex-direction: column;
      gap: 0;
    }

    .header__link {
      padding: 0.75rem 0.5rem;
      font-size: 1rem;
    }
  }
</style>
