---
import site from '../data/site.json';

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about/' },
  { label: 'Players & Families', href: '/services/players/' },
  { label: 'Clubs & Institutions', href: '/services/institutions/' },
  { label: 'Partnerships', href: '/partnerships/academies/' },
  { label: 'Football Education', href: '/education/the-football-room/' },
  { label: 'Testimonials', href: '/testimonials/' },
  { label: 'FAQs', href: '/faqs/' },
];
---

<header class="header">
  <div class="header__inner container">
    <a href="/" class="header__brand">
      <img
        src={site.profileImage}
        alt="Michael Mulhern Football Consultancy"
        class="header__logo-img"
        width="40"
        height="40"
      />
    </a>

    <button class="header__toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="header__toggle-bar"></span>
      <span class="header__toggle-bar"></span>
      <span class="header__toggle-bar"></span>
    </button>

    <nav class="header__nav" aria-label="Main navigation">
      <ul class="header__list">
        {navItems.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class:list={['header__link', { 'header__link--active': currentPath === href || (href !== '/' && currentPath.startsWith(href.replace(/\/$/, ''))) }]}
            >
              {label}
            </a>
          </li>
        ))}
        <li class="header__cta-item">
          <a href="/contact/" class="header__cta">Get in Touch</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector('.header__toggle');
  const nav = document.querySelector('.header__nav');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    nav?.classList.toggle('header__nav--open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-white);
    border-bottom: 1px solid var(--color-grey-200);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4.25rem;
  }

  .header__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .header__logo-img {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    object-fit: cover;
  }

  .header__nav {
    display: flex;
    align-items: center;
  }

  .header__list {
    display: flex;
    align-items: center;
    gap: 0.125rem;
    list-style: none;
  }

  .header__link {
    display: block;
    padding: 0.5rem 0.75rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-grey-600);
    border-radius: 4px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .header__link:hover {
    color: var(--color-navy);
    background-color: var(--color-grey-100);
  }

  .header__link--active {
    color: var(--color-navy);
    font-weight: 600;
  }

  .header__cta-item {
    margin-left: 0.75rem;
  }

  .header__cta {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-white);
    background-color: var(--color-gold);
    border-radius: 4px;
    transition: background-color 0.2s ease, transform 0.1s ease;
  }

  .header__cta:hover {
    background-color: var(--color-gold-hover);
    transform: translateY(-1px);
  }

  .header__toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  .header__toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-navy);
    border-radius: 1px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 768px) {
    .header__toggle {
      display: flex;
    }

    .header__nav {
      display: none;
      position: absolute;
      top: 4.25rem;
      left: 0;
      right: 0;
      background-color: var(--color-white);
      border-bottom: 1px solid var(--color-grey-200);
      padding: 1rem 1.5rem;
    }

    .header__nav--open {
      display: block;
    }

    .header__list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .header__link {
      padding: 0.75rem 0.5rem;
      font-size: 1rem;
    }

    .header__cta-item {
      margin-left: 0;
      margin-top: 0.75rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--color-grey-200);
    }

    .header__cta {
      display: block;
      text-align: center;
      padding: 0.75rem 1.25rem;
    }
  }
</style>
